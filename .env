# Copy to .env in this folder. Start DB from repo root: docker compose up -d

# Database (port 5438 = docker-compose at monorepo root)
DATABASE_URL=postgresql://revenue_user:revenue_pass@127.0.0.1:5438/revenue_intelligence?schema=public
DIRECT_URL=postgresql://revenue_user:revenue_pass@127.0.0.1:5438/revenue_intelligence?schema=public
M10_DATABASE_URL=postgresql://revenue_user:revenue_pass@127.0.0.1:5438/revenue_intelligence?schema=public

# Redis
REDIS_URL=redis://localhost:6379
DISABLE_REDIS=false

# Meilisearch (optional — set DISABLE_MEILI=true if not running)
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=masterkey
DISABLE_MEILI=true

# AI services (optional — set DISABLE_AI=true if not running)
AI_SERVICES_URL=http://localhost:8000
DISABLE_AI=true

# Auth (local dev)
JWT_SECRET=local-dev-secret-change-me
JWT_EXPIRES_IN=1d

# Provider keys (placeholders)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here


