generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "postgresqlExtensions"]
  output          = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["dashboards", "public", "ingestion", "revenuegraph"]
}

// ─────────────────────────────────────────────────────────────
// Platform Core
// ─────────────────────────────────────────────────────────────
model Tenant {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       String       @unique
  status     TenantStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  accounts   Account[]
  calls      Call[]
  dashboards Dashboard[]
  datasets   Dataset[]
  deals      Deal[]
  users      User[]

  @@schema("public")
}

model User {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid      String         @db.Uuid
  email         String
  passwordHash  String
  name          String
  role          UserRole
  status        UserStatus     @default(ACTIVE)
  lastLoginAt   DateTime?
  dashboards    Dashboard[]    @relation("DashboardOwner")
  tenant        Tenant         @relation(fields: [tenantid], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@unique([tenantid, email])
  @@index([tenantid, role])
  @@schema("public")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@schema("public")
}

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED

  @@schema("public")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED

  @@schema("public")
}

model Account {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid       String   @db.Uuid
  externalId     String?
  name           String
  ownerName      String?
  industry       String?
  /// Canonical rep for boards/filters (maps assigned_rep_id in CRM store)
  assignedRepId  String?  @map("assigned_rep_id")
  /// HubSpot owner object id — CRM sync only, not used for app filtering
  hubspotOwnerId String?  @map("hubspot_owner_id")
  /// Platform User.id (M01 auth) when account is tied to a logged-in owner
  ownerUserId    String?  @map("owner_user_id")
  healthScore    Float?   @map("healthscore")
  crmRecordId    String?  @map("crm_record_id")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantid], references: [id], onDelete: Cascade)
  deals          Deal[]

  @@index([tenantid, name])
  @@index([tenantid, assignedRepId])
  @@schema("revenuegraph")
}

model Deal {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid        String    @db.Uuid
  externalId      String?
  accountId       String?   @db.Uuid
  ownerId         String?
  name            String
  amount          Decimal   @db.Decimal(18, 2)
  stage           String
  closeDate       DateTime?
  quarter         String
  isWon           Boolean   @default(false)
  confidenceScore Int?
  riskScore       Int?
  riskLabel       String?
  riskFlags       String[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  account         Account?  @relation(fields: [accountId], references: [id])
  tenant          Tenant    @relation(fields: [tenantid], references: [id], onDelete: Cascade)

  // Deal boards integration fields
  ownerName        String?
  ownerEmail       String?
  forecastCategory String?
  probability      Int?
  dealType         String?
  aiScore          Int?
  meddpiccScore    Int?
  nextStep         String?
  lastActivity     DateTime?
  pipeline         String?   @default("default")
  escalated        Boolean?  @default(false)
  warningsCount    Int?      @default(0)
  contactsCount    Int?      @default(1)
  startDate        DateTime?

  @@index([tenantid, quarter, ownerId])
  @@index([tenantid, quarter])
  @@schema("revenuegraph")
}

model Call {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid       String   @db.Uuid
  externalId     String?
  dealId         String?  @db.Uuid
  accountId      String?  @db.Uuid
  ownerName      String?
  durationSec    Int?
  occurredAt     DateTime
  transcriptText String?
  tenant         Tenant   @relation(fields: [tenantid], references: [id], onDelete: Cascade)

  @@index([tenantid, occurredAt])
  @@schema("ingestion")
}

model Dataset {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid        String                @db.Uuid
  createdById     String                @db.Uuid
  name            String
  description     String?
  sourceMode      String
  dataSourceId    String?               @db.Uuid
  selectedObjects Json
  selectedFields  Json
  mappingStatus   String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  tenant          Tenant                @relation(fields: [tenantid], references: [id], onDelete: Cascade)
  dataSource      DataSource?           @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  relationships   DatasetRelationship[]
  datasetObjects  DatasetObject[]
  datasetFields   DatasetField[]

  @@index([tenantid, createdById])
  @@schema("revenuegraph")
}

model DatasetRelationship {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  datasetId         String             @db.Uuid
  sourceObject      String
  sourceField       String
  targetObject      String
  targetField       String
  status            RelationshipStatus
  validationMessage String?
  dataset           Dataset            @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId, status])
  @@schema("revenuegraph")
}

model Dashboard {
  id             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid       String                   @db.Uuid
  ownerId        String                   @db.Uuid
  datasetId      String?
  title          String
  description    String?
  visibility     DashboardShareVisibility @default(PRIVATE)
  status         DashboardStatus          @default(DRAFT)
  isTemplate     Boolean                  @default(false)
  shareToken     String?                  @unique
  snapshot       Json?
  lastSnapshotAt DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  owner          User                     @relation("DashboardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tenant         Tenant                   @relation(fields: [tenantid], references: [id], onDelete: Cascade)
  widgets        Widget[]

  @@index([tenantid, ownerId])
  @@schema("public")
}

model Widget {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dashboardId String     @db.Uuid
  type        WidgetType
  title       String
  config      Json
  position    Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  dashboard   Dashboard  @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  tenantid    String     @db.Uuid

  @@index([dashboardId, position])
  @@index([tenantid, dashboardId])
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model coachingrecommendations {
  recid              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshotid         String   @db.Uuid
  tenantid           String   @db.Uuid
  userid             String   @db.Uuid
  recommendationtext String
  category           String?
  confidencescore    Decimal? @db.Decimal
  generatedat        DateTime @default(now()) @db.Timestamptz(6)

  @@index([tenantid, snapshotid, generatedat(sort: Desc)], map: "idx_coachingrecommendations_tenant_snapshot")
  @@schema("dashboards")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model coachingsnapshots {
  snapshotid       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid         String   @db.Uuid
  userid           String   @db.Uuid
  period           String
  talkratio        Decimal? @db.Decimal
  longestmonologue Decimal? @db.Decimal
  questionrate     Decimal? @db.Decimal
  interactivity    Decimal? @db.Decimal
  toptopics        Json?
  callcount        Int?
  computedat       DateTime @default(now()) @db.Timestamptz(6)

  @@unique([tenantid, userid, period], map: "uq_coachingsnapshots_tenant_user_period")
  @@index([tenantid, userid, period], map: "idx_coachingsnapshots_tenant_user_period")
  @@schema("dashboards")
}

/// Per-user dashboard layout persistence (M07). Canonical model — maps to dashboards.dashboardconfigs.
/// Former duplicate `dashboard_configs` table model removed (unused at runtime).
model DashboardConfig {
  configId         String   @id @default(dbgenerated("gen_random_uuid()")) @map("configid") @db.Uuid
  tenantid         String   @map("tenantid") @db.Uuid
  userId           String   @map("userid") @db.Uuid
  layout           Json
  visibleWidgets   Json?    @map("visiblewidgets")
  dateRangeDefault String?  @map("daterangedefault")
  createdAt        DateTime @default(now()) @map("createdat") @db.Timestamptz(6)

  @@unique([tenantid, userId], map: "uq_dashboardconfigs_tenant_user")
  @@index([tenantid, userId], map: "idx_dashboardconfigs_tenant_user")
  @@map("dashboardconfigs")
  @@schema("dashboards")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DashboardSnapshot {
  snapshotId      String   @id @default(dbgenerated("gen_random_uuid()")) @map("snapshot_id") @db.Uuid
  tenantid        String   @map("tenant_id") @db.Uuid
  periodKey       String   @map("period_key")
  metricName      String   @map("metric_name")
  dimensionScopes Json     @map("dimension_scopes")
  dimensionKey    String   @map("dimension_key")
  cachedValue     Decimal  @map("cached_value") @db.Decimal(18, 4)
  computedAt      DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantid, periodKey, metricName, dimensionKey], map: "uq_dashboard_snapshots_tenant_period_metric_dimkey")
  @@index([tenantid, periodKey, metricName], map: "idx_dashboard_snapshots_tenant_period_metric")
  @@map("dashboard_snapshots")
  @@schema("dashboards")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model trainerscenarios {
  scenarioid         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid           String   @db.Uuid
  name               String
  personadescription String?
  context            String?
  difficulty         String?
  scorecardid        String?  @db.Uuid
  createdby          String   @db.Uuid
  createdat          DateTime @default(now()) @db.Timestamptz(6)

  @@index([tenantid, createdat(sort: Desc)], map: "idx_trainerscenarios_tenant_created")
  @@schema("dashboards")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model trainersessions {
  sessionid       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scenarioid      String    @db.Uuid
  tenantid        String    @db.Uuid
  userid          String    @db.Uuid
  conversation    Json
  scorecardresult Json?
  status          String
  completedat     DateTime? @db.Timestamptz(6)
  createdat       DateTime  @default(now()) @db.Timestamptz(6)

  @@index([tenantid, userid, status, createdat(sort: Desc)], map: "idx_trainersessions_tenant_user_status")
  @@schema("dashboards")
}

model DataSource {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid     String   @db.Uuid
  sourceName   String
  sourceType   String
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())

  objects  DataSourceObject[]
  datasets Dataset[]

  @@schema("revenuegraph")
}

model DataSourceObject {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dataSourceId String   @db.Uuid
  objectName   String
  displayName  String
  createdAt    DateTime @default(now())

  dataSource     DataSource        @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  fields         DataSourceField[]
  datasetObjects DatasetObject[]

  @@map("data_source_objects")
  @@schema("revenuegraph")
}

model DataSourceField {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  objectId    String   @db.Uuid
  fieldName   String
  displayName String
  fieldType   String
  createdAt   DateTime @default(now())

  object        DataSourceObject @relation(fields: [objectId], references: [id], onDelete: Cascade)
  datasetFields DatasetField[]

  @@unique([objectId, fieldName])
  @@map("data_source_fields")
  @@schema("revenuegraph")
}

model DataSourceRelationship {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceObjectId   String
  targetObjectId   String
  relationshipType String
  sourceField      String
  targetField      String
  createdAt        DateTime @default(now())

  @@map("data_source_relationships")
  @@schema("revenuegraph")
}

model DatasetObject {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  datasetId String @db.Uuid
  objectId  String @db.Uuid

  dataset          Dataset          @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  dataSourceObject DataSourceObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@schema("revenuegraph")
}

model DatasetField {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  datasetId String @db.Uuid
  fieldId   String @db.Uuid

  dataset         Dataset         @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  dataSourceField DataSourceField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@schema("revenuegraph")
}

model Team {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid  String   @db.Uuid
  name      String
  parentId  String?  @db.Uuid
  parent    Team?    @relation("TeamHierarchy", fields: [parentId], references: [id])
  children  Team[]   @relation("TeamHierarchy")
  managerId String?  @db.Uuid
  members   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantid])
  @@schema("revenuegraph")
}

model DashboardAccess {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid    String   @db.Uuid
  dashboardId String   @db.Uuid
  userId      String   @db.Uuid
  grantedBy   String
  canView     Boolean  @default(true)
  canEdit     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([dashboardId, userId])
  @@index([tenantid, dashboardId])
  @@schema("revenuegraph")
}

enum UserRole {
  ADMIN
  MANAGER
  SALES_REP
  ANALYST
  EXECUTIVE

  @@schema("public")
}

enum RelationshipStatus {
  AUTO_DETECTED
  MANUAL_OVERRIDE
  REJECTED

  @@schema("public")
}

enum DashboardShareVisibility {
  PRIVATE
  TEAM
  LINK

  @@schema("public")
}

enum WidgetType {
  KPI
  BAR
  LINE
  PIE
  FUNNEL
  AREA
  COLUMN
  DONUT
  GAUGE
  TABLE
  PERFORMANCE
  ATTAINMENT_TREND
  FORECAST
  TRENDS
  CHANGES

  @@schema("public")
}

enum DashboardStatus {
  DRAFT
  PUBLISHED

  @@schema("public")
}

// ─────────────────────────────────────────────────────────────
// M-01: Capture & Transcription
// ─────────────────────────────────────────────────────────────

/// A recorded call or meeting registered in the platform (CT-01, CT-02, CT-13)
model CallRecord {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid String @db.Uuid

  // Metadata fields shown on Call Detail header (CT-13)
  title           String
  callDate        DateTime
  durationSeconds Int      @default(0)
  callType        String // inbound | outbound | meeting
  callSource      String // zoom | teams | meet | dialer | manual
  participants    String[] // display names / emails of all attendees
  callOwner       String // userId of the rep who owns the call
  accountId       String?  @db.Uuid // linked CRM account
  opportunityId   String?  @db.Uuid // linked CRM opportunity

  // Audio storage (CT-02, CT-17)
  audioUrl String? // signed URL to stored recording

  // Transcription lifecycle (CT-01, CT-09, US-09, US-31)
  transcriptStatus String  @default("pending")
  // pending | processing | completed | failed | skipped
  failureReason    String? // populated when status = failed (CT-09)
  skipReason       String? // populated when status = skipped (US-09) e.g. 'below_minimum_duration' | 'transcription_disabled'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transcript        Transcript?
  notes             CallNote[]
  shares            CallShare[]
  extractionResults AiExtractionResult[]
  themeMappings     ThemeCallMapping[]
  themeQuotes       ThemeQuote[]

  @@index([tenantid])
  @@index([tenantid, callDate])
  @@index([tenantid, transcriptStatus])
  @@map("call_records")
  @@schema("ingestion")
}

/// Full transcript associated with a call (CT-03, CT-04, CT-18)
model Transcript {
  id       String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid String     @db.Uuid
  callId   String     @unique @db.Uuid
  call     CallRecord @relation(fields: [callId], references: [id], onDelete: Cascade)

  // Full text used for full-text search (CT-05)
  fullText String

  // AI-generated fields (CT-14, CT-15, CT-24)
  summary       String?
  keyHighlights Json?
  // [{label: "pricing", text: "...", timestampMs: 45000}]
  nextSteps     String[]
  talkRatio     Json?
  // {rep: {speakerLabel: "A", percentage: 0.42}, customer: {speakerLabel: "B", percentage: 0.58}}

  // AssemblyAI job tracking
  assemblyAiJobId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  utterances Utterance[]

  @@index([tenantid])
  @@index([tenantid, callId])
  // GIN index for full-text search (US-06) — requires PostgreSQL extension
  // Run: CREATE INDEX idx_transcripts_fulltext ON transcripts USING GIN(to_tsvector('english', "fullText"));
  @@map("transcripts")
  @@schema("ingestion")
}

/// A single speaker turn within a transcript (CT-03, CT-11, CT-12, CT-18, CT-19, CT-20)
model Utterance {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transcriptId String     @db.Uuid
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  // tenantId mirrors the parent transcript for RLS enforcement (US-32)
  tenantid String @db.Uuid

  speaker         String // "Rep" | "Customer" | "Speaker 1" | "Speaker 2" (US-03 fallback)
  text            String // utterance text — PII-redacted before storage (US-04, US-16)
  originalText    String? // raw pre-redaction text retained for internal audit only
  startMs         Int // start position in audio (milliseconds) (CT-19)
  endMs           Int // end position in audio (milliseconds)
  confidence      Float // 0.0 – 1.0 from AssemblyAI (CT-12)
  isLowConfidence Boolean @default(false)
  // true when confidence < 0.80 (CT-12, CT-20)

  sequenceIndex Int // ordering within transcript

  @@index([tenantid])
  @@index([transcriptId])
  @@index([transcriptId, sequenceIndex])
  // GIN index for keyword search within utterances (US-06)
  // Run: CREATE INDEX idx_utterances_text ON utterances USING GIN(to_tsvector('english', "text"));
  @@map("utterances")
  @@schema("ingestion")
}

/// Notes added by a rep or manager on a specific call (CT-22)
model CallNote {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid  String     @db.Uuid
  callId    String     @db.Uuid
  call      CallRecord @relation(fields: [callId], references: [id], onDelete: Cascade)
  authorId  String     @db.Uuid // userId of the note author
  content   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([callId])
  @@index([tenantid])
  @@map("call_notes")
  @@schema("ingestion")
}

/// Record of sharing a call with another user or team (CT-23)
model CallShare {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid       String     @db.Uuid
  callId         String     @db.Uuid
  call           CallRecord @relation(fields: [callId], references: [id], onDelete: Cascade)
  sharedByUserId String     @db.Uuid
  sharedWithId   String     @db.Uuid // userId or teamId
  sharedWithType String // "user" | "team"
  sharedAt       DateTime   @default(now())

  @@unique([callId, sharedWithId, sharedWithType])
  @@index([tenantid])
  @@index([callId])
  @@map("call_shares")
  @@schema("ingestion")
}

// ────────────────────────────────────────────────────────────
/// Immutable audit trail of all significant system and user events (US-30)
/// Records: config changes, job events, call shares, transcript edits
model AuditLog {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid String @db.Uuid

  // Who and what
  actorId    String? @db.Uuid // userId of the person who triggered the action (null = system)
  actorType  String  @default("system") // "user" | "system" | "worker"
  action     String // e.g. 'transcription.completed' | 'pii.redacted' | 'call.shared'
  entityType String // e.g. 'CallRecord' | 'Transcript' | 'CallShare'
  entityId   String // ID of the affected entity

  // Context
  meta Json? // arbitrary additional data (e.g. { reason, oldValue, newValue })

  createdAt DateTime @default(now())

  @@index([tenantid, createdAt(sort: Desc)])
  @@index([tenantid, entityId])
  @@index([tenantid, action])
  @@map("audit_logs")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────
// Platform Core: Native Connectors (shared across all modules)
// ─────────────────────────────────────────────────────────────

/// OAuth integration record for external services (HubSpot, Google, Zoom, Teams, Gmail)
model Integration {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid     String    @db.Uuid
  provider     String // hubspot | google_calendar | zoom | teams | gmail
  status       String    @default("disconnected") // connected | disconnected | expired
  accountEmail String? // email/account used for this integration
  accountName  String? // display name of the connected account
  accessToken  String? // encrypted OAuth access token
  refreshToken String? // encrypted OAuth refresh token
  tokenExpiry  DateTime?
  scopes       String[] // granted OAuth scopes
  metadata     Json? // provider-specific metadata (e.g. hubspot portal ID)
  connectedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantid, provider])
  @@index([tenantid])
  @@map("integrations")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────
// M03: AI Summaries & GenAI
// ─────────────────────────────────────────────────────────────

model AiBrief {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid         String   @db.Uuid
  briefType        String
  entityId         String
  generatedSummary String?  @db.Text
  generationStatus String?  @default("pending")
  sourceReferences Json?
  llmModel         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantid, briefType, entityId])
  @@index([tenantid, briefType])
  @@map("ai_briefs")
  @@schema("public")
}

model AiChatHistory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid  String   @db.Uuid
  userId    String?  @db.Uuid
  question  String   @db.Text
  answer    String   @db.Text
  citations Json?
  createdAt DateTime @default(now())

  @@index([tenantid, createdAt])
  @@map("ai_chat_history")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────
// M-18: AI Data Extractor
// ─────────────────────────────────────────────────────────────

/// Extraction field definition — a "question" the AI answers for every transcript
/// Phase 1: Users create these in the Extraction Library
model AiExtractionField {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid String @db.Uuid

  // The question / field definition
  question       String // e.g. "What competitor was mentioned?"
  fieldLabel     String // display label e.g. "Competitor Mentioned"
  fieldName      String // machine name, snake_case e.g. "competitor_mentioned"
  dataType       String // "text" | "boolean" | "number" | "date" | "enum"
  enumOptions    String[] // only used when dataType = "enum"
  extractionHint String? // optional hint to guide the AI extraction

  // CRM mapping (optional)
  crmObject String? // "Deal" | "Account" | "Contact"
  crmField  String? // e.g. "Competitor__c"

  // Lifecycle
  isActive     Boolean @default(false)
  displayOrder Int     @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdByUserId String?

  results AiExtractionResult[]

  @@index([tenantid])
  @@index([tenantid, isActive])
  @@map("m18_ai_extraction_fields")
  @@schema("public")
}

/// Extraction result — the AI's answer to a field question for a specific call
/// Phase 3: Auto-populated when transcription completes
model AiExtractionResult {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantid String @db.Uuid

  fieldId String            @db.Uuid
  field   AiExtractionField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  callId String     @db.Uuid
  call   CallRecord @relation(fields: [callId], references: [id], onDelete: Cascade)

  // Extracted data
  extractedValue      String? // null = "Not yet detected"
  rawEvidence         String? // verbatim quote from transcript
  evidenceTimestampMs Int? // milliseconds into the call (for audio seek)
  confidenceScore     Float? // 0.0 – 1.0

  // Override tracking
  isManualOverride   Boolean @default(false)
  overriddenByUserId String?

  extractedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([fieldId, callId])
  @@index([tenantid, callId])
  @@index([tenantid, fieldId])
  @@map("m18_ai_extraction_results")
  @@schema("public")
}

